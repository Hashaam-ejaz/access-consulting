---
// src/components/LogoGrid.astro
interface Props {
    logos: Array<{
        src: string
        name: string
        class?: string
    }>
}
const { logos = [] } = Astro.props as Props
---

<div class="flex w-full flex-wrap items-center justify-center gap-x-8 gap-y-10">
    {
        logos.map((logo) => (
            <div class="flex shrink-0 basis-[calc(50%-1rem)] items-center justify-center sm:basis-[calc(33.333%-1.334rem)] lg:basis-[calc(25%-1.5rem)]">
                <img
                    src={logo.src}
                    alt={logo.name}
                    class:list={[
                        "h-14 w-auto max-w-[180px] object-contain opacity-60 grayscale transition duration-300 hover:opacity-100 hover:grayscale-0 md:h-16",
                        logo.class,
                    ]}
                />
            </div>
        ))
    }
</div>
