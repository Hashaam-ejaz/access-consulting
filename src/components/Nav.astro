---
const items = [
  { name: "Study Abroad", href: "/study-abroad" },
  { name: "Careers & Work Visas", href: "/careers-visas" },
  { name: "Consulting", href: "/consulting" },
  { name: "Proven Results", href: "/proven-results" },
  { name: "Blog", href: "/blog" },
  { name: "Contact", href: "/contact" },
];
---

<header class="w-full">
  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-8 px-6 py-4">
    <a href="/" class="shrink-0 whitespace-nowrap text-2xl font-semibold text-ink">
      Access Consulting
    </a>

    <ul class="hidden items-center gap-6 lg:flex">
      {items.map((item) => (
        <li>
          <a
            href={item.href}
            class="whitespace-nowrap text-sm font-medium text-ink/80 transition-colors hover:text-primary"
          >
            {item.name}
          </a>
        </li>
      ))}
    </ul>

    <a
      href="/consultancy"
      class="hidden shrink-0 rounded-full bg-ink px-6 py-2.5 text-sm font-medium text-white transition-colors duration-300 hover:bg-primary lg:inline-block"
    >
      Get Started
    </a>
  </nav>
</header>