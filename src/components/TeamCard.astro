---
type Props = {
    name: string
    role: string
    image: string
    linkedin?: string
}
const { name, role, image, linkedin = "" } = Astro.props as Props
---

<div class="group text-center">
    <div
        class="relative mx-auto aspect-square w-full overflow-hidden rounded-2xl bg-sky-soft">
        <img
            src={image}
            alt={name}
            class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
        />
    </div>
    <div class="mt-4">
        <div class="font-semibold text-ink">{name}</div>
        <div class="mt-0.5 text-sm text-ink/60">{role}</div>
        {
            linkedin && (
                <a
                    href={linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${name} on LinkedIn`}
                    class="mt-2 inline-flex text-ink/40 transition-colors hover:text-primary">
                    <svg
                        class="h-5 w-5"
                        viewBox="0 0 24 24"
                        fill="currentColor">
                        <path d="M4.98 3.5a2.5 2.5 0 11-.01 5.001A2.5 2.5 0 014.98 3.5zM3 8.98h4v12H3v-12zM9.5 8.98h3.8v1.64h.05c.53-1 1.83-2.06 3.77-2.06 4.03 0 4.78 2.65 4.78 6.1v6.32h-4v-5.6c0-1.34-.02-3.06-1.87-3.06-1.87 0-2.16 1.46-2.16 2.96v5.7h-4v-12z" />
                    </svg>
                </a>
            )
        }
    </div>
</div>
