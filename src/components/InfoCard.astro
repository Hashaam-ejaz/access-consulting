---
const { title, desc, icon = "", meta = "", href = "" } = Astro.props
const Tag = href ? "a" : "div"
---

<Tag
    href={href || undefined}
    class:list={[
        "flex h-full flex-col rounded-2xl border border-ink/10 bg-white p-6",
        href &&
            "transition-all hover:-translate-y-1 hover:border-primary/40 hover:shadow-lg",
    ]}>
    {icon && <div class="mb-4 text-3xl">{icon}</div>}
    <h3 class="text-lg font-semibold text-ink">{title}</h3>
    <p class="mt-2 flex-1 text-ink/70">{desc}</p>
    {meta && <div class="mt-4 text-sm font-medium text-primary">{meta}</div>}
</Tag>
