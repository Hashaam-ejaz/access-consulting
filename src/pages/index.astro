---

<BaseLayout>
    <!-- Hero Section -->
    <Section class="bg-linear-to-b from-[#d0e7ff] to-white">
        <Heading class="text-center">
            Your Gateway to Global Education & Strategic Careers.
        </Heading>
        <span
            class="text-center lg:text-2xl md:text-xl text-lg tracking-tight text-ink lg:w-10/12 mx-auto md:mb-7.5 mb-4">
            Led by Germany-based experts with nearly 9 years of academic and
            corporate experience. We bridge the gap between Pakistani talent and
            top-tier global destinations.
        </span>
        <div class="flex">
            <Button href="/consulting"> Get Started </Button>
        </div>
    </Section>

    <!-- Stats Bar -->
    <Section class="bg-white">
        <div class="grid w-full grid-cols-2 gap-8 md:grid-cols-4">
            {
                stats.map((s) => (
                    <div class="text-center">
                        <div class="text-3xl font-semibold text-primary md:text-4xl">
                            {s.value}
                        </div>
                        <p class="mt-1 text-sm text-ink/70 md:text-base">
                            {s.label}
                        </p>
                    </div>
                ))
            }
        </div>
    </Section>

    <!-- Harris Azhar -->
    <Section class="bg-white">
        <div class="grid w-full items-center gap-12 lg:grid-cols-2">
            <!-- text -->
            <div>
                <span
                    class="text-sm font-medium uppercase tracking-widest text-primary">
                    Who we are
                </span>
                <h2
                    class="mt-4 text-3xl font-semibold tracking-tight text-ink md:text-4xl">
                    We've walked the path we guide you through.
                </h2>
                <p class="mt-5 text-lg leading-relaxed text-ink/70">
                    Access Consulting was founded by Harris Azhar, a German
                    national of Pakistani origin who navigated the same
                    admissions, visa, and career decisions our clients face
                    today. That lived experience — combined with nearly a decade
                    in European academia and industry — is what separates
                    genuine guidance from generic advice.
                </p>

                <ul class="mt-7 space-y-3">
                    {
                        founderPoints.map((point) => (
                            <li class="flex gap-3 text-ink/80">
                                <svg
                                    class="mt-1 h-5 w-5 shrink-0 text-primary"
                                    viewBox="0 0 20 20"
                                    fill="currentColor">
                                    <path
                                        fill-rule="evenodd"
                                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.7-9.7a1 1 0 00-1.4-1.4L9 10.2 7.7 8.9a1 1 0 00-1.4 1.4l2 2a1 1 0 001.4 0l4-4z"
                                        clip-rule="evenodd"
                                    />
                                </svg>
                                <span>{point}</span>
                            </li>
                        ))
                    }
                </ul>

                <div class="mt-9 flex flex-wrap gap-4">
                    <Button href="/about">Meet the team</Button>
                    <Button href="/consultancy" variant="secondary"
                        >Book a free call</Button
                    >
                </div>
            </div>

            <!-- founder video -->
            <div class="relative overflow-hidden rounded-3xl bg-sky-soft">
                <!-- <video
                    class="aspect-4/5 w-full object-cover"
                    autoplay
                    muted
                    loop
                    playsinline
                    poster="/team/harris-poster.jpg">
                    <source src="/video/harris-intro.mp4" type="video/mp4" />
                </video> -->
                <img
                    src="/team/harris.png"
                    alt="Harris Azhar, Founder"
                    class="aspect-4/5 w-full object-cover"
                />
                <div
                    class="absolute inset-x-0 bottom-0 bg-linear-to-t from-black/70 to-transparent p-6">
                    <div class="font-semibold text-white">Harris Azhar</div>
                    <div class="text-sm text-white/70">Founder</div>
                </div>
            </div>
        </div>
    </Section>

    <!-- Pathways -->
    <Section class="bg-white">
        <Heading class="text-center">Six pathways. One trusted team.</Heading>
        <div class="mt-10 grid w-full gap-6 md:grid-cols-2 lg:grid-cols-3">
            {pathways.map((p) => <PathwayCard {...p} />)}
        </div>
    </Section>

    <!-- Network & Corporate Foundations -->
    <Section class="bg-white">
        <Heading class="text-center"
            >Our Network & Corporate Foundations</Heading
        >
        <p class="mb-10 max-w-2xl text-center text-ink/70">
            The academic and professional institutions our consultants have
            studied and worked with.
        </p>
        <LogoGrid logos={networkLogos} />
    </Section>

    <!-- Team -->
    <Section class="bg-blue-100">
        <Heading class="text-center">Real people. Real experience.</Heading>
        <p class="mx-auto mb-12 max-w-2xl text-center text-ink/70">
            A team spread across Germany, Pakistan, and North America — each
            advising in the areas they've lived through themselves.
        </p>

        <div class="flex w-full flex-wrap justify-center gap-8">
            {
                team.map((member) => (
                    <div class="basis-[calc(50%-1rem)] sm:basis-[calc(33.333%-1.334rem)] lg:basis-[calc(25%-1.5rem)]">
                        <TeamCard {...member} />
                    </div>
                ))
            }
        </div>
    </Section>

    <!-- Testimonials -->
    <Section class="bg-blue-100">
        <Heading class="text-center">What our students say</Heading>
        <div class="mt-10 flex w-full flex-wrap justify-center gap-6">
            {
                testimonials.map((t) => (
                    <div class="basis-full md:basis-[calc(50%-0.75rem)] lg:basis-[calc(33.333%-1rem)]">
                        <TestimonialCard {...t} />
                    </div>
                ))
            }
        </div>
        <Button href="/proven-results" variant="secondary" class="mt-10">
            View all proven results →
        </Button>
    </Section>

    <!-- Giving Back -->
    <Section class="bg-ink text-white">
        <div class="max-w-3xl text-center">
            <span
                class="text-sm font-medium uppercase tracking-widest text-white/50">
                Giving back
            </span>
            <h2 class="mt-4 text-2xl font-semibold md:text-3xl">
                A commitment to building the future.
            </h2>
            <p class="mt-5 text-lg leading-relaxed text-white/70">
                A dedicated percentage of all Access Consulting revenue directly
                funds &nbsp;
                <a
                    href="https://hamaragharcenter.com/"
                    target="_blank"
                    class="font-medium text-white">
                    Hamara Ghar Welfare Trust
                </a>, supporting the education and shelter of orphan girls in
                Islamabad.
            </p>
        </div>
    </Section>
</BaseLayout>
