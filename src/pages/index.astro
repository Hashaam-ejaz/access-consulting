---
import Section from "../components/Section.astro"
import BaseLayout from "../layouts/BaseLayout.astro"
import Heading from "../components/Heading.astro"
import Button from "../components/Button.astro"
import PathwayCard from "../components/PathwayCard.astro"
import LogoGrid from "../components/LogoGrid.astro"
import TestimonialCard from "../components/TestimonialCard.astro"

const stats = [
    { value: "9+", label: "Years European experience" },
    { value: "100%", label: "Transparent process" },
    { value: "100%", label: "Visa success rate" },
    { value: "500+", label: "Students & professionals assisted" },
]

const pathways = [
    {
        icon: "🎓",
        title: "Master's & Bachelor's Admissions",
        desc: "End-to-end guidance for undergrad and graduate admissions at top global universities.",
        href: "/study-abroad",
        badge: "Video coming soon",
    },
    {
        icon: "🧭",
        title: "Career Mapping & Job Strategy",
        desc: "Position yourself for the international job market with a tailored career roadmap.",
        href: "/careers-visas",
    },
    {
        icon: "🔬",
        title: "PhD Mapping & Strategy",
        desc: "Find the right supervisor, funding, and programme for your research path.",
        href: "/phd",
    },
    {
        icon: "🔧",
        title: "Ausbildung (Vocational Training)",
        desc: "Paid vocational training placements in Germany with a route to residency.",
        href: "/ausbildung",
    },
    {
        icon: "🛂",
        title: "Skilled Worker Visa / Chancenkarte",
        desc: "Navigate Germany's skilled-worker and opportunity-card visa routes.",
        href: "/careers-visas",
    },
    {
        icon: "📚",
        title: "IELTS Academic & General Prep",
        desc: "Structured prep to hit the band score your application needs.",
        href: "/consulting/ielts",
        badge: "Video coming soon",
    },
]

const networkLogos = [
    { name: "LUMS", src: "/logos/lums.png" },
    {
        name: "constructor University",
        src: "/logos/constructor.svg",
        class: "invert",
    },
    { name: "Central European University", src: "/logos/ceu.svg" },
    { name: "NUST", src: "/logos/ nust.png" },
    { name: "Jacobs University Bremen", src: "/logos/jacobs.png" },
    { name: "Max Planck Institute", src: "/logos/max-planck.png" },
    { name: "Deloitte", src: "/logos/deloitte.png" },
    { name: "BlackRock", src: "/logos/blackrock.png" },
    { name: "Moonfare", src: "/logos/moonfare.svg" },
    { name: "Wermuth Asset Management", src: "/logos/wermuth.svg" },
    { name: "United Nations", src: "/logos/un.png" },
    { name: "Government of Pakistan", src: "/logos/gop.svg" },
    { name: "Cadet College Jhang", src: "/logos/ccj.png" },
    {
        name: "Cadet College Malir Cantt",
        src: "/logos/ccmk.png",
    },
    { name: "HTW", src: "/logos/htw.svg" },
]

const testimonials = [
    {
        quote: "AA! Got some amazing news today. Alhamdulillah, I've been selected for an internship. Thank you for your support.",
        name: "Alia K.",
    },
    {
        quote: "Visa recieved today alhamdolillah - JazakAllah for everything.",
        name: "Saima K.",
    },
    {
        quote: "Assalamualaikum! Alhamdulillah I got selected for a werkstudent position.",
        name: "Talal K.",
    },
    {
        quote: "Visa recieved; thanks so much. JazakAllah for your support throughout the process.",
        name: "Bilal M.",
    },
]
---

<BaseLayout>
    <Section class="bg-linear-to-b from-[#d0e7ff] to-white">
        <Heading class="text-center">
            Your Gateway to Global Education & Strategic Careers.
        </Heading>
        <span
            class="text-center lg:text-2xl md:text-xl text-lg tracking-tight text-ink lg:w-10/12 mx-auto md:mb-7.5 mb-4">
            Led by Germany-based experts with nearly 9 years of academic and
            corporate experience. We bridge the gap between Pakistani talent and
            top-tier global destinations.
        </span>
        <div class="flex">
            <Button href="/consulting"> Get Started </Button>
        </div>
    </Section>

    <Section class="bg-white">
        <div class="grid w-full grid-cols-2 gap-8 md:grid-cols-4">
            {
                stats.map((s) => (
                    <div class="text-center">
                        <div class="text-3xl font-semibold text-primary md:text-4xl">
                            {s.value}
                        </div>
                        <p class="mt-1 text-sm text-ink/70 md:text-base">
                            {s.label}
                        </p>
                    </div>
                ))
            }
        </div>
    </Section>

    <Section class="bg-white">
        <Heading class="text-center">Six pathways. One trusted team.</Heading>
        <div class="mt-10 grid w-full gap-6 md:grid-cols-2 lg:grid-cols-3">
            {pathways.map((p) => <PathwayCard {...p} />)}
        </div>
    </Section>

    <Section class="bg-white">
        <Heading class="text-center"
            >Our Network & Corporate Foundations</Heading
        >
        <p class="mb-10 max-w-2xl text-center text-ink/70">
            The academic and professional institutions our consultants have
            studied and worked with.
        </p>
        <LogoGrid logos={networkLogos} />
    </Section>

    <Section class="bg-ink text-white">
        <div class="max-w-3xl text-center">
            <span
                class="text-sm font-medium uppercase tracking-widest text-white/50">
                Giving back
            </span>
            <h2 class="mt-4 text-2xl font-semibold md:text-3xl">
                A commitment to building the future.
            </h2>
            <p class="mt-5 text-lg leading-relaxed text-white/70">
                A dedicated percentage of all Access Consulting revenue directly
                funds &nbsp;
                <a
                    href="https://hamaragharcenter.com/"
                    target="_blank"
                    class="font-medium text-white">
                    Hamara Ghar Welfare Trust
                </a>, supporting the education and shelter of orphan girls in
                Islamabad.
            </p>
        </div>
    </Section>

    <Section class="bg-blue-100">
        <Heading class="text-center">What our students say</Heading>
        <div class="mt-10 flex w-full flex-wrap justify-center gap-6">
            {
                testimonials.map((t) => (
                    <div class="basis-full md:basis-[calc(50%-0.75rem)] lg:basis-[calc(33.333%-1rem)]">
                        <TestimonialCard {...t} />
                    </div>
                ))
            }
        </div>
        <Button href="/proven-results" variant="secondary" class="mt-10">
            View all proven results →
        </Button>
    </Section>
</BaseLayout>
